import urllib2
import ssl
if __name__ == '__main__':
    myurl='https://www.baidu.com'
    req = urllib2.Request(myurl)
try:
response = urllib2.urlopen(req)
print 'HTTP return code:%d' % response.getcode()
strResult= response.read()
print strResult
except Exception ,ex:
print 'Found Error :%s' % str(ex)