if 条件1:    #此条件不成立，往下一个判断
    语句块1
elif 条件2-1 and 条件2-2:    #此条件成立（两个条件同时成立），不再判断，直接运行语句块2
    语句块2
elif 条件3-1 or 条件3-2:    #两个条件中有一个成立，整个条件都成立
    语句块3
elif (条件a and 条件b) or 条件c:    #如果条件a和条件b同时成立时，运行语句A。或者条件c成立时，运行语句A
    语句A
elif str in Str:    #当str中的字符串在Str中，条件成立（not in反之）
    语句B
else:
    语句块4    #如果没有这个语句（或者这个语句为pass的时候），else可以不写。（即所有条件都不成立时，直接跳过整个if语句）