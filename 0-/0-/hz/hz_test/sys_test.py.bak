counter_right = 0
counter_lost = 0
lun_input = int(input('测试的轮数：'))
lun = 1
while lun <= lun_input:
    counter_ = 0
    for url in urls:
        url = url%(mobile)
        counter_all =+ 1
        counter_ =+ 1
        print('已测试%s次，成功%s次，失败%s次\n当前测试的地址%s'%(counter_all,counter_right,counter_lost,url))
        re = requests.get(url=url, headers=headers)
        code = re.status_code
        if code == 200:
            counter_right =+ 1
            result = re.text
            print('结果:\n%s'%(result))
        else:
            counter_lost =+ 1
            print('狗，又是用不了的接口，go die!!\n错误代码：%s'%(code))
    lun_input = lun_input +1
else:
    print('已完成，每轮测试%s次，%s轮，共%s次'%(counter_,lun_input,conter_all))
    