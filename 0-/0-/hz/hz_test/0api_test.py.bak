import wget


urls = []
with open('./0test_api.txt', encoding='utf-8') as f:
	for line in f:
		urls.append(line.strip('\n').split(',')[0])#将txt文件转为list，每行为一个元素

counter_all = 0
for url in urls:
    counter_all =+ 1
    print('已测试%s次\n当前测试的地址%s'%(counter_all,url))
    with open('./result.txt','a') as fp:
        fp.write(url+'\n')
    wget.download(url,'./result.txt','a')
    with open('./result.txt','a') as fp:
        fp.write('\n'+'-'*20+'\n')